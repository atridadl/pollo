rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  	function isSignedIn() {
      return request.auth != null;
    }
    
    function existingData() {
      return resource.data;
    }

    function resourceMatchesUID() {
        return request.auth.uid == existingData().ownerUID;
    }

    match /questions/{dbID} {
      allow read: if true;
      allow write: if isSignedIn() && resourceMatchesUID();
    }
    
    match /polls/{dbID} {
      allow read: if true;
      allow write: if isSignedIn() && resourceMatchesUID();
    }
  }
}